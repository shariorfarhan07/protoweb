# Copy to .env and fill in values before running docker compose up

# Public host of this server (IP or domain, no scheme/port). Used by
# docker-compose.yml for CORS and the URLs baked into the frontend build:
#   frontend -> http://SERVER_HOST:5555   backend API -> http://SERVER_HOST:8888
SERVER_HOST=localhost

# PostgreSQL password (no special chars that break connection strings)
POSTGRES_PASSWORD=changeme

# Public-facing URLs baked into the Next.js build
NEXT_PUBLIC_API_URL=https://prototypebd.com/api/v1
NEXT_PUBLIC_SITE_URL=https://prototypebd.com
