# Backend API base URL (no trailing slash, no /api/v1)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Public site URL (used for SEO meta, sitemap, og:image)
NEXT_PUBLIC_SITE_URL=https://prototypebd.com

# ── Marketing & analytics (all optional — tags load only when set) ──────
# Google Analytics 4 measurement ID
NEXT_PUBLIC_GA_ID=
# Google Tag Manager container ID
NEXT_PUBLIC_GTM_ID=
# Meta (Facebook/Instagram) Pixel ID — needed for FB/IG ads & retargeting
NEXT_PUBLIC_META_PIXEL_ID=
# Google Search Console verification token
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
