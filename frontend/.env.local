# Backend API base URL (no trailing slash, no /api/v1)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Used by next.config.mjs to proxy /static/* → backend
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Public site URL (used for SEO meta, sitemap, og:image)
NEXT_PUBLIC_SITE_URL=https://prototypebd.com
