# Backend API base URL — must be reachable from the BROWSER, so use the
# machine's LAN IP (not localhost) when serving other devices on the network.
NEXT_PUBLIC_API_URL=http://192.168.0.178:8000/api/v1

# Used by next.config.mjs to proxy /static/* → backend
NEXT_PUBLIC_BACKEND_URL=http://192.168.0.178:8000

# Public site URL (used for SEO meta, sitemap, og:image)
NEXT_PUBLIC_SITE_URL=http://192.168.0.178:3000
