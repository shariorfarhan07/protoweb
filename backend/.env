# Database — SQLite (default) or PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./prototypebd.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/prototypebd

# CORS — comma-separated origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5555","http://localhost:8888"]

# API
API_PREFIX=/api/v1

# JWT
SECRET_KEY=prototypebd-super-secret-key-change-in-production-min32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
